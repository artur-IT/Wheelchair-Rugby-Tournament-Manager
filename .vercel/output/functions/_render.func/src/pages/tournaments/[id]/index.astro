import TournamentDetails from "@/features/tournaments/components/TournamentDetails/TournamentDetails";

const { id } = Astro.params;
if (!id) return Astro.redirect("/tournaments");
---

<Layout title="Szczegóły turnieju">
  <TournamentDetails id={id} client:load />
</Layout>
