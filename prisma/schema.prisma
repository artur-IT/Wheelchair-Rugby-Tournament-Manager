generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Phase 1: MVP ────────────────────────────────────────────────────────────

model User {
  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  password    String
  role        UserRole
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum UserRole {
  COACH
  ORGANIZER
}

model Season {
  id          String       @id @default(cuid())
  name        String
  year        Int?
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  teams       Team[]
  coaches     Coach[]
  referees    Referee[]
  classifiers Classifier[]
  tournaments Tournament[]
}

model Team {
  id               String           @id @default(cuid())
  name             String
  websiteUrl       String?
  address          String?
  city             String?
  postalCode       String?
  contactFirstName String?
  contactLastName  String?
  contactEmail     String?
  contactPhone     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  seasonId         String
  season           Season           @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  coachId          String?
  coach            Coach?           @relation(fields: [coachId], references: [id], onDelete: SetNull)
  refereeId        String?
  referee          Referee?         @relation(fields: [refereeId], references: [id], onDelete: SetNull)
  players          Player[]
  staff            Staff[]
  tournaments      TournamentTeam[]
  matchesAsTeamA   Match[] @relation("TeamA")
  matchesAsTeamB   Match[] @relation("TeamB")
}

model Staff {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tournaments TournamentStaff[]
}

model Player {
  id                  String               @id @default(cuid())
  firstName           String
  lastName            String
  number              Int?
  classification      Float?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  teamId              String
  team                Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  classificationExams ClassificationExam[]
  tournaments         TournamentPlayer[]

  @@unique([teamId, number])
}

model Tournament {
  id           String                 @id @default(cuid())
  name         String
  startDate    DateTime
  endDate      DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  seasonId     String
  season       Season                 @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  venues        SportsHall[]
  accommodations Accommodation[]
  mealPlans    MealPlan[]
  teams        TournamentTeam[]
  referees     TournamentReferee[]
  classifiers  TournamentClassifier[]
  matches              Match[]
  classificationExams  ClassificationExam[]
  volunteers           Volunteer[]
  players              TournamentPlayer[]
  staffMembers         TournamentStaff[]
}

// ─── Phase 2: Season details ──────────────────────────────────────────────────

model Coach {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  seasonId  String
  season    Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  teams     Team[]
}

model Referee {
  id          String              @id @default(cuid())
  firstName   String
  lastName    String
  email       String?
  phone       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  seasonId    String
  season      Season              @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  teams       Team[]
  tournaments TournamentReferee[]
  assignments RefereeAssignment[]
}

model Classifier {
  id                  String                 @id @default(cuid())
  firstName           String
  lastName            String
  email               String?
  phone               String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  seasonId            String
  season              Season                 @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  tournaments         TournamentClassifier[]
  classificationExams ClassificationExam[]
}

// ─── Phase 2: Tournament details ─────────────────────────────────────────────

model SportsHall {
  id           String     @id @default(cuid())
  name         String
  city         String?
  street       String?
  postalCode   String?
  notes        String?
  mapUrl       String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tournamentId String
  tournament   Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model Accommodation {
  id           String     @id @default(cuid())
  name         String
  address      String?
  notes        String?
  mapUrl       String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

enum MealLocation {
  HALL
  HOTEL
  OTHER
}

model MealPlan {
  id           String       @id @default(cuid())
  location     MealLocation
  details      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tournamentId String
  tournament   Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

// ─── Phase 2: Junction tables ─────────────────────────────────────────────────

model TournamentTeam {
  tournamentId String
  teamId       String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([tournamentId, teamId])
}

model TournamentReferee {
  tournamentId String
  refereeId    String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  referee      Referee    @relation(fields: [refereeId], references: [id], onDelete: Cascade)

  @@id([tournamentId, refereeId])
}

model TournamentClassifier {
  tournamentId String
  classifierId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  classifier   Classifier @relation(fields: [classifierId], references: [id], onDelete: Cascade)

  @@id([tournamentId, classifierId])
}

// Tournament-specific player roster (subset of team's season roster)
model TournamentPlayer {
  tournamentId String
  playerId     String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player       Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@id([tournamentId, playerId])
}

// Tournament-specific staff roster (subset of team's season staff)
model TournamentStaff {
  tournamentId String
  staffId      String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  staff        Staff      @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@id([tournamentId, staffId])
}

// ─── Phase 2: Matches & scheduling ───────────────────────────────────────────

enum MatchStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Match {
  id                 String              @id @default(cuid())
  scheduledAt        DateTime
  court              String?
  jerseyInfo         String?
  scoreA             Int?
  scoreB             Int?
  status             MatchStatus         @default(SCHEDULED)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  tournamentId       String
  tournament         Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamAId            String
  teamA              Team                @relation("TeamA", fields: [teamAId], references: [id])
  teamBId            String
  teamB              Team                @relation("TeamB", fields: [teamBId], references: [id])
  refereeAssignments RefereeAssignment[]
}

enum RefereeRole {
  REFEREE_1
  REFEREE_2
  TABLE_CLOCK
  TABLE_PENALTY
}

model RefereeAssignment {
  id        String      @id @default(cuid())
  role      RefereeRole
  matchId   String
  match     Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  refereeId String
  referee   Referee     @relation(fields: [refereeId], references: [id])

  @@unique([matchId, refereeId])
  @@unique([matchId, role])
}

// Classifier examines a player during a tournament
model ClassificationExam {
  id           String     @id @default(cuid())
  scheduledAt  DateTime?
  location     String?
  result       Float?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  classifierId String
  classifier   Classifier @relation(fields: [classifierId], references: [id])
  playerId     String
  player       Player     @relation(fields: [playerId], references: [id])

  @@unique([tournamentId, classifierId, playerId])
}

model Volunteer {
  id           String     @id @default(cuid())
  firstName    String
  lastName     String
  phone        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}
